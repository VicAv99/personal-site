---
import MainLayout from "./MainLayout.astro";
import { Icon } from "astro-icon";

export interface Props {
  content: {
    title: string;
    description: string;
    pubDate: string;
    readingTime: string;
  };
}

const {
  content: { title, description, pubDate, readingTime },
} = Astro.props;
---

<MainLayout title={title} description={description}>
  <article>
    <h2 class="text-4xl font-semibold">{title}</h2>

    <div class="pt-4 text-zinc-400">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-x-2">
          <time class="text-base">Victor Avila</time>
          <span>-</span>
          <time class="text-base">{pubDate}</time>
        </div>
        <span class="text-base">{readingTime}</span>
      </div>
      <!-- <span>•</span> -->
    </div>
    <hr class="border-(t t-neutral-700) my-8" />
    <slot />
  </article>
</MainLayout>
