---
import MainLayout from "./MainLayout.astro";
import ViewsComponent from "../components/ViewsComponent.astro";

export interface Props {
  content: {
    title: string;
    description: string;
    pubDate: string;
    readingTime: string;
  };
}

const {
  url,
  content: { title, description, pubDate, readingTime },
} = Astro.props;

const slug = url.split("/blog/").join("");
---

<MainLayout title={title} description={description}>
  <article>
    <h2 class="mb-0 text-4xl">{title}</h2>

    <div class="pt-4 text-zinc-400">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-x-2">
          <span class="text-base">{readingTime}</span>
          <span>-</span>
          <time class="text-base">{pubDate}</time>
        </div>
        <div class="flex items-center gap-x-2">
          <time class="text-base">Victor Avila</time>
          <span>-</span>
          <ViewsComponent isBlogPage />
        </div>
      </div>
      <!-- <span>•</span> -->
    </div>
    <hr class="border-(t t-neutral-700) mt-4 mb-6" />
    <slot />
  </article>
</MainLayout>
