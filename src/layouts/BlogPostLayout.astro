---
import MainLayout from "./MainLayout.astro";
import { Icon } from "astro-icon";

export interface Props {
  content: {
    title: string;
    description: string;
    pubDate: string;
    readingTime: string;
  };
}

const {
  content: { title, description, pubDate, readingTime },
} = Astro.props;
---

<MainLayout title={title} description={description}>
  <main>
    <article>
      <h2 class="text-2xl font-semibold">{title}</h2>

      <div class="pt-4 text-zinc-400">
        <div class="flex items-center gap-x-2">
          <Icon name="mdi:calendar" class="w-5" />

          <time class="text-base">{pubDate}</time>
        </div>

        <div class="flex items-center gap-x-2">
          <Icon name="mdi:clock" class="w-5" />

          <span class="text-base">{readingTime}</span>
        </div>
      </div>
      <hr class="border-(t t-neutral-700) my-8" />
      <slot />
    </article>
  </main>
</MainLayout>
